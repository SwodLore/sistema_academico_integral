# Variables de entorno del backend.
# En LOCAL no necesitas este archivo: application.properties tiene valores por defecto.
# En PRODUCCION (Render) estas variables se configuran en el dashboard, no en un archivo.

# Conexion a MySQL (Aiven te da estos datos al crear el servicio)
DB_URL=jdbc:mysql://HOST:PUERTO/defaultdb?ssl-mode=REQUIRED
DB_USERNAME=avnadmin
DB_PASSWORD=TU_PASSWORD

# En produccion usar "update" (con "create" la BD se borra en cada reinicio)
DDL_AUTO=update
SHOW_SQL=false

# Genera uno nuevo, por ejemplo con: openssl rand -hex 32
JWT_SECRET=CAMBIA_ESTE_SECRETO_POR_UNO_NUEVO

# URL del frontend en Vercel (separar con coma si hay varias)
CORS_ORIGINS=https://TU-FRONTEND.vercel.app

# URL publica del backend en Render (para el QR de los certificados)
APP_BASE_URL=https://TU-BACKEND.onrender.com
